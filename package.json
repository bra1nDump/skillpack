{
  "name": "skillbench",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "qa:links": "node scripts/qa/check-links.mjs",
    "qa:publish": "npm run lint && npm run build && npm run qa:links",
    "screenshots": "node scripts/capture-screenshots.mjs",
    "metrics:collect": "node scripts/collect-stars.mjs",
    "metrics:downloads": "node scripts/collect-downloads.mjs",
    "metrics:mentions": "node scripts/collect-mentions.mjs",
    "metrics:all": "node scripts/collect-stars.mjs && node scripts/collect-downloads.mjs && node scripts/collect-mentions.mjs",
    "ralph": "node scripts/ralph.mjs",
    "ralph:loop": "node scripts/ralph.mjs --loop"
  },
  "dependencies": {
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "playwright": "^1.58.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
